# Base environment variables for the examples in this directory.
# This file is safe to commit — it contains no secrets.
#
# To override values locally without committing them,
# copy relevant lines to .env.local (which is gitignored).

BASE_URL=https://jsonplaceholder.typicode.com

# Placeholder values — override in .env.local with real credentials.
AUTH_TOKEN=
POST_TITLE=Hello from sail
POST_BODY=Sent via the sail CLI
